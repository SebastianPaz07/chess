# Database
DATABASE_URL="postgresql://user:password@localhost:5432/chess_study"

# NextAuth
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Lichess OAuth (obtener en https://lichess.org/account/oauth/app/create)
LICHESS_CLIENT_ID="your-lichess-client-id"
LICHESS_CLIENT_SECRET="your-lichess-client-secret"

# Storage para PDFs (opcional, para Fase 3)
# AWS_S3_BUCKET="chess-study-books"
# AWS_ACCESS_KEY_ID="your-access-key"
# AWS_SECRET_ACCESS_KEY="your-secret-key"

# Redis (opcional, para caché en producción)
# REDIS_URL="redis://localhost:6379"

# Monitoring (opcional)
# SENTRY_DSN="your-sentry-dsn"
